{
    "name": "ecoapm/libyear",
    "version": "3.1.2",
    "description": "A simple measure of software dependency freshness",
    "homepage": "https://libyear.com",
    "readme": "README.md",
    "license": "MIT",
    "authors": [
        {
            "name": "ecoAPM",
            "email": "steve@ecoAPM.com",
            "homepage": "https://ecoAPM.com"
        }
    ],
    "bin": [
        "libyear"
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "^8.1",
        "composer/semver": "^3.4",
        "guzzlehttp/guzzle": "^8.0",
        "vanilla/garden-cli": "^v4.0",
        "wp-cli/php-cli-tools": "^v0.13"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "ecoAPM\\LibYear\\": "src/",
            "ecoAPM\\LibYear\\Tests\\": "tests/"
        }
    }
}
